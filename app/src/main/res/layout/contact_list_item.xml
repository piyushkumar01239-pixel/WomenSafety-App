<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/contactNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Name"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/contactPhoneText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+91 98765 43210"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/contactRelationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mother"
            android:textSize="11sp"
            android:textColor="#999999"
            android:layout_marginTop="1dp"/>

        <!-- Email badge — shown only if email is set -->
        <TextView
            android:id="@+id/contactEmailText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📧 email@example.com"
            android:textSize="11sp"
            android:textColor="#2980B9"
            android:layout_marginTop="2dp"
            android:visibility="gone"/>

    </LinearLayout>

    <Button
        android:id="@+id/deleteContactButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Delete"
        android:textColor="#FFFFFF"
        android:backgroundTint="#E74C3C"
        android:layout_gravity="center_vertical"/>

</LinearLayout>