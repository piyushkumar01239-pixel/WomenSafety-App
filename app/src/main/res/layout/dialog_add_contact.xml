<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Emergency Contact"
        android:textSize="20sp"
        android:textColor="#E74C3C"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/dialogContactName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Contact Name *"
        android:inputType="textPersonName"
        android:padding="12dp"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/dialogContactPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Phone Number *"
        android:inputType="phone"
        android:padding="12dp"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/dialogContactRelation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Relationship (e.g., Mother, Friend)"
        android:inputType="text"
        android:padding="12dp"
        android:layout_marginBottom="10dp"/>

    <!-- NEW: Email field for email alerts -->
    <EditText
        android:id="@+id/dialogContactEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="📧 Email (optional — for email alerts)"
        android:inputType="textEmailAddress"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 Add email to also send SOS alert via email"
        android:textSize="11sp"
        android:textColor="#888888"
        android:layout_marginBottom="16dp"/>

</LinearLayout>